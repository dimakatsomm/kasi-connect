NODE_ENV=development
PORT=3000

# WhatsApp / Meta Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v18.0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SESSION_TTL=1800

# PostgreSQL / Huawei GaussDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kasiconnect
DB_USER=kasiconnect
DB_PASSWORD=your_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DATABASE_URL=postgresql://kasiconnect:your_db_password_here@localhost:5432/kasiconnect?schema=public

# Kafka / Huawei DMS
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kasi-connect
KAFKA_GROUP_ID=kasi-connect-group

# Huawei OBS (Object Storage)
OBS_ENDPOINT=https://obs.af-south-1.myhuaweicloud.com
OBS_BUCKET=kasiconnect-media
OBS_ACCESS_KEY=your_obs_access_key_here
OBS_SECRET_KEY=your_obs_secret_key_here

# AI / Huawei ModelArts
MODELARTS_ENDPOINT=https://modelarts.af-south-1.myhuaweicloud.com
MODELARTS_ACCESS_KEY=your_modelarts_access_key_here
MODELARTS_SECRET_KEY=your_modelarts_secret_key_here
STT_MODEL_ID=your_stt_model_id_here

# Session config
SESSION_INACTIVITY_TIMEOUT_MS=1800000
